// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url      = env("vehicle_DATABASE_URL")
  directUrl = env("vehicle_DATABASE_URL_UNPOOLED")
}

model Vehicle {
  id            String   @id @default(cuid())
  year          Int
  make          String
  model         String
  trim          String?
  price         Float
  mileage       Int
  color         String
  vin           String?  @unique
  engine        String?
  transmission  String?
  fuelType      String?
  condition     String?
  vehicleType   String
  status        String   @default("pending")
  dailyRate     Float?
  weeklyRate    Float?
  featured      Boolean  @default(false)
  images        String   @default("[]")
  description   String?
  createdAt     DateTime @default(now())

  rentalApplications     RentalApplication[]
  purchaseApplications   PurchaseApplication[]
  contactInquiries       ContactInquiry[]

  @@index([make, model])
  @@index([status])
  @@index([vehicleType])
}

model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  text      String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([status])
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  vehicleId String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([read])
  @@index([vehicleId])
}

model RentalApplication {
  id               String   @id @default(cuid())
  customerName     String
  customerPhone    String
  customerEmail    String
  customerAddress  String
  driverLicense    String?
  vehicleId        String
  startDate        DateTime
  endDate          DateTime
  hasInsurance     Boolean  @default(false)
  insuranceDoc     String?
  dealerInsurance  Float?
  agreedToTerms    Boolean  @default(false)
  status           String   @default("pending")
  createdAt        DateTime @default(now())

  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([status])
  @@index([vehicleId])
}

model PurchaseApplication {
  id              String   @id @default(cuid())
  customerName    String
  customerPhone   String
  customerEmail   String
  customerAddress String
  vehicleId       String
  agreedToTerms   Boolean  @default(false)
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([status])
  @@index([vehicleId])
}

model WholesaleVehicle {
  id          String   @id @default(cuid())
  year        Int
  make        String
  model       String
  price       Float
  mileage     Int
  location    String
  radius      Int      @default(250)
  images      String   @default("[]")
  description String?
  status      String   @default("available")
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([location])
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}
